# ─────────────────────────────────────────────────────────────────────────────
# CRM Sequence Automator — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=pat-na2-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_SENDER=your-sending-address@gmail.com
Client_ID=your-google-oauth-client-id.apps.googleusercontent.com
Client_Secret=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# ── Throttle / Scheduling ─────────────────────────────────────────────────────
MAX_EMAILS_PER_DAY=150
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
SENDER_TIMEZONE=America/Chicago
STALLED_DAYS=14

# ── Dashboard API ─────────────────────────────────────────────────────────────
# URL the React frontend uses to reach the FastAPI backend.
# Dev:  http://localhost:8000
# Prod: https://your-domain.com  (or the server IP/port)
VITE_API_BASE_URL=http://localhost:8000

# ── Security (production only) ────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Dev:  *  (leave blank to allow all)
# Prod: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=*

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "production" to disable --reload and enable structured JSON logging
APP_ENV=development
